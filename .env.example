# ════════════════════════════════════════════════════════════════
# JARVIS v9.2 — Complete Environment Variables
# Priority: best-first. Add what you have, rest auto-fallback.
# ════════════════════════════════════════════════════════════════

# ─── REQUIRED (minimum 1 from each) ─────────────────────────────
NEXT_PUBLIC_GEMINI_API_KEY=     # aistudio.google.com — 1500 req/day FREE
GROQ_API_KEY=                   # console.groq.com — 6K tokens/min FREE

# ─── LLM PROVIDERS (cascade: top = first tried) ──────────────────
# Puter.js         — Unlimited, NO KEY, browser-side auto
DEEPSEEK_API_KEY=               # platform.deepseek.com — free tier, best reasoning
MISTRAL_API_KEY=                # console.mistral.ai — 1 BILLION tokens/month FREE
XAI_API_KEY=                    # console.x.ai — Grok 3 Fast, free tier
OPENROUTER_API_KEY=             # openrouter.ai — 30+ free models, one key
TOGETHER_API_KEY=               # api.together.xyz — $25 free, Llama 4 Scout
COHERE_API_KEY=                 # cohere.com — Command-A, free beta
AIMLAPI_KEY=                    # aimlapi.com — GPT-4o mini, free credits
HUGGINGFACE_TOKEN=              # huggingface.co/settings/tokens — rate limited
# ApiFreeLLM      — NO KEY needed, auto fallback

# ─── TTS PROVIDERS (cascade: best quality first) ─────────────────
GOOGLE_TTS_KEY=                 # cloud.google.com — 1M chars/month, best Hindi
ELEVENLABS_API_KEY=             # elevenlabs.io — 10K chars/month, most realistic
AZURE_TTS_KEY=                  # portal.azure.com — 500K chars/month
AZURE_REGION=eastus
PLAYHT_API_KEY=                 # play.ht — 12.5K words/month
PLAYHT_USER_ID=
OPENAI_API_KEY=                 # platform.openai.com — free credits
FISH_AUDIO_KEY=                 # fish.audio — free credits
# Browser Speech  — NO KEY, unlimited fallback

# ─── IMAGE PROVIDERS ─────────────────────────────────────────────
# Puter.js         — Unlimited, NO KEY, browser-side (DALL-E 3)
# Gemini Imagen    — uses NEXT_PUBLIC_GEMINI_API_KEY above
# Pollinations     — NO KEY, unlimited, auto fallback
DEEPAI_KEY=                     # deepai.org/api — free tier

# ─── MUSIC PROVIDERS ─────────────────────────────────────────────
# HuggingFace MusicGen — uses HUGGINGFACE_TOKEN above
MUBERT_API_KEY=                 # mubert.com/api — royalty-free, free tier
# Suno/Udio/AIVA   — link-based, no key needed

# ─── STORAGE (cascade: cloud first, local fallback) ──────────────
NEXT_PUBLIC_SUPABASE_URL=       # supabase.com — 500MB free, cross-device sync
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_FIREBASE_API_KEY=   # console.firebase.google.com — 1GB free
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# IndexedDB        — NO KEY, device local, offline works
# localStorage     — NO KEY, always works, 5MB limit

# ─── SOCIAL INTEGRATIONS ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=             # t.me/BotFather — unlimited FREE ✅ (easiest)
TELEGRAM_CHAT_ID=
META_APP_ID=                    # developers.facebook.com — Instagram + Facebook
META_APP_SECRET=
TWITTER_BEARER_TOKEN=           # developer.twitter.com — 1500 tweets/month
NEXT_PUBLIC_GOOGLE_CLIENT_ID=   # console.cloud.google.com — Calendar + Gmail OAuth
GOOGLE_CLIENT_SECRET=

# ─── INDIA TOOLS ─────────────────────────────────────────────────
YOUTUBE_API_KEY=                # console.cloud.google.com — 10K units/day
NASA_API_KEY=                   # api.nasa.gov — free
NEWSDATA_API_KEY=               # newsdata.io — 200 req/day free
TMDB_API_KEY=                   # themoviedb.org — free
PEXELS_API_KEY=                 # pexels.com/api — free
EXCHANGERATE_API_KEY=           # exchangerate-api.com — free tier
WAQI_API_KEY=                   # aqicn.org/api — air quality free

# ─── SCHEDULER ───────────────────────────────────────────────────
CRON_SECRET=jarvis-cron-2025    # change this to something secret

# ─── STORAGE — ADDITIONAL (cascade: add any you have) ───────────
# Upstash Redis — FASTEST, serverless-perfect, free 10K req/day
UPSTASH_REDIS_URL=              # upstash.com → Create DB → REST URL
UPSTASH_REDIS_TOKEN=            # upstash.com → Create DB → REST Token

# Turso — 9GB free, 1 BILLION rows/month, SQLite at edge
TURSO_DB_URL=                   # libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=               # turso.tech → DB → Settings → Token

# MongoDB Atlas — Data API REST, 512MB free
MONGODB_DATA_API_URL=           # mongodb.com/atlas → App Services → Data API
MONGODB_DATA_API_KEY=           # mongodb.com/atlas → App Services → API Key
MONGODB_DB=jarvis               # database name (default: jarvis)
