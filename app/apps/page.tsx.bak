'use client'
// app/apps/page.tsx — JARVIS Apps Hub v1
// 50+ app integrations, smart search, one-tap launch
// Zero OAuth · Zero API · Pure deep links

import { useState, useMemo } from 'react'
import { useRouter } from 'next/navigation'
import BottomNav from '../../components/shared/BottomNav'
import {
  APPS, CATEGORIES, CATEGORY_ICONS, findApps, openApp, getAppUrl,
  type AppDef, type AppAction, type Category,
} from '../../lib/integrations/apps'

// ── Theme ─────────────────────────────────────────────────
const BG     = '#090d18'
const CARD   = 'rgba(255,255,255,.04)'
const BORDER = 'rgba(255,255,255,.07)'
const ACCENT = '#00e5ff'
const DIM    = '#4a6080'

// ── Category colors ──────────────────────────────────────
const CAT_COLORS: Record<string, string> = {
  'AI Tools':     '#a78bfa',
  'Design':       '#f472b6',
  'Code':         '#34d399',
  'Docs':         '#60a5fa',
  'Productivity': '#fbbf24',
  'Media':        '#f87171',
  'Images':       '#e879f9',
  'PDF & Files':  '#fb923c',
  'Education':    '#4ade80',
  'India':        '#ff8c00',
  'Communication':'#38bdf8',
  'Finance':      '#6ee7b7',
}

// ── App Card ─────────────────────────────────────────────
function AppCard({ app, compact }: { app: AppDef; compact?: boolean }) {
  const [expanded, setExpanded] = useState(false)
  const color = CAT_COLORS[app.category] || ACCENT

  if (compact) {
    return (
      <div
        onClick={() => openApp(app)}
        style={{
          padding: '8px 6px', borderRadius: 10,
          background: CARD, border: `1px solid ${BORDER}`,
          cursor: 'pointer', textAlign: 'center',
          transition: 'all .15s',
        }}
      >
        <div style={{ fontSize: 22 }}>{app.emoji}</div>
        <div style={{ fontSize: 9, color: '#a0b8d0', marginTop: 3, lineHeight: 1.3 }}>
          {app.name.replace(' AI','').replace(' Web','').slice(0,12)}
        </div>
      </div>
    )
  }

  return (
    <div style={{
      borderRadius: 12, background: CARD,
      border: `1px solid ${expanded ? color + '40' : BORDER}`,
      overflow: 'hidden', transition: 'all .15s',
    }}>
      {/* Main row */}
      <div
        style={{ padding: '11px 13px', display: 'flex', alignItems: 'center', gap: 10, cursor: 'pointer' }}
        onClick={() => {
          if (app.actions && app.actions.length > 1) setExpanded(!expanded)
          else openApp(app)
        }}
      >
        <div style={{
          width: 38, height: 38, borderRadius: 10, flexShrink: 0,
          background: `${color}18`,
          border: `1px solid ${color}30`,
          display: 'flex', alignItems: 'center', justifyContent: 'center', fontSize: 20,
        }}>
          {app.emoji}
        </div>
        <div style={{ flex: 1, minWidth: 0 }}>
          <div style={{ fontSize: 13, fontWeight: 600, color: '#e8f4ff' }}>{app.name}</div>
          <div style={{ fontSize: 10, color: DIM, lineHeight: 1.4, marginTop: 1 }}>{app.desc}</div>
        </div>
        <div style={{ display: 'flex', alignItems: 'center', gap: 6 }}>
          {app.india && <span style={{ fontSize: 9, padding: '2px 5px', borderRadius: 4, background: 'rgba(255,140,0,.1)', color: '#ff8c00', border: '1px solid rgba(255,140,0,.2)' }}>🇮🇳</span>}
          {app.actions && app.actions.length > 1
            ? <span style={{ fontSize: 11, color: DIM }}>{expanded ? '▲' : '▼'}</span>
            : <span style={{ fontSize: 13, color: DIM }}>↗</span>
          }
        </div>
      </div>

      {/* Actions dropdown */}
      {expanded && app.actions && (
        <div style={{ padding: '0 10px 10px', display: 'flex', flexWrap: 'wrap', gap: 6 }}>
          {app.actions.map(action => (
            <button
              key={action.id}
              onClick={(e) => { e.stopPropagation(); openApp(app, action.id) }}
              style={{
                padding: '6px 10px', borderRadius: 8, border: `1px solid ${color}30`,
                background: `${color}10`, color, fontSize: 11, cursor: 'pointer',
                display: 'flex', alignItems: 'center', gap: 4,
              }}
            >
              {action.icon} {action.label}
            </button>
          ))}
        </div>
      )}
    </div>
  )
}

// ═══════════════════════════════════════════════════════════
// MAIN PAGE
// ═══════════════════════════════════════════════════════════
export default function AppsPage() {
  const router = useRouter()
  const [query,     setQuery]     = useState('')
  const [activeCat, setActiveCat] = useState<Category | 'All' | 'India'>('All')
  const [view,      setView]      = useState<'list' | 'grid'>('list')

  // Search or filter
  const displayApps = useMemo(() => {
    if (query.length > 1) return findApps(query, 20)
    if (activeCat === 'All') return APPS
    if (activeCat === 'India') return APPS.filter(a => a.india)
    return APPS.filter(a => a.category === activeCat)
  }, [query, activeCat])

  // Quick-access: most useful apps (pinned)
  const PINNED = ['chatgpt','gemini','perplexity','canva','figma','excalidraw','github','replit','gdocs','wolfram','desmos','pw','irctc','youtube','whatsapp','ilovepdf','unsplash','remove_bg','gtranslate','gcal']
  const pinnedApps = PINNED.map(id => APPS.find(a => a.id === id)).filter(Boolean) as AppDef[]

  return (
    <div style={{
      minHeight: '100vh', background: BG, color: '#e8f4ff', display: 'flex',
      flexDirection: 'column', fontFamily: "'Noto Sans Devanagari',system-ui,sans-serif",
      maxWidth: 480, margin: '0 auto',
    }}>

      {/* Header */}
      <header style={{ padding: '14px 16px 10px', borderBottom: `1px solid ${BORDER}`, background: BG, position: 'sticky', top: 0, zIndex: 10 }}>
        <div style={{ display: 'flex', alignItems: 'center', gap: 10, marginBottom: 10 }}>
          <div style={{ width: 34, height: 34, borderRadius: 10, background: 'rgba(0,229,255,.1)', border: `1px solid rgba(0,229,255,.2)`, display: 'flex', alignItems: 'center', justifyContent: 'center', fontSize: 18 }}>🔗</div>
          <div style={{ flex: 1 }}>
            <div style={{ fontSize: 15, fontWeight: 700, color: ACCENT }}>Apps Hub</div>
            <div style={{ fontSize: 10, color: DIM }}>{APPS.length} apps · One-tap launch · Zero login</div>
          </div>
          <button
            onClick={() => setView(v => v === 'list' ? 'grid' : 'list')}
            style={{ padding: '5px 8px', borderRadius: 7, background: CARD, border: `1px solid ${BORDER}`, color: DIM, fontSize: 14, cursor: 'pointer' }}
            title="Toggle view"
          >
            {view === 'list' ? '⊞' : '☰'}
          </button>
        </div>

        {/* Search */}
        <div style={{ position: 'relative' }}>
          <span style={{ position: 'absolute', left: 12, top: '50%', transform: 'translateY(-50%)', fontSize: 14, color: DIM }}>🔍</span>
          <input
            value={query}
            onChange={e => { setQuery(e.target.value); setActiveCat('All') }}
            placeholder="Search apps... (canva, neet, pdf, code...)"
            style={{
              width: '100%', padding: '9px 12px 9px 36px', borderRadius: 10,
              background: 'rgba(255,255,255,.05)', border: `1px solid ${BORDER}`,
              color: '#e8f4ff', fontSize: 13, outline: 'none', boxSizing: 'border-box',
            }}
          />
          {query && (
            <button onClick={() => setQuery('')} style={{ position: 'absolute', right: 10, top: '50%', transform: 'translateY(-50%)', background: 'none', border: 'none', color: DIM, cursor: 'pointer', fontSize: 16 }}>✕</button>
          )}
        </div>
      </header>

      <main style={{ flex: 1, overflowY: 'auto', paddingBottom: 90 }}>

        {/* Quick access grid (shown when no search) */}
        {!query && activeCat === 'All' && (
          <div style={{ padding: '14px 16px 0' }}>
            <div style={{ fontSize: 10, color: DIM, marginBottom: 8, display: 'flex', justifyContent: 'space-between' }}>
              <span>⚡ Quick Launch</span>
              <span>{pinnedApps.length} apps</span>
            </div>
            <div style={{ display: 'grid', gridTemplateColumns: 'repeat(5,1fr)', gap: 8, marginBottom: 16 }}>
              {pinnedApps.slice(0, 20).map(app => (
                <AppCard key={app.id} app={app} compact />
              ))}
            </div>
            <div style={{ height: 1, background: BORDER, marginBottom: 14 }} />
          </div>
        )}

        {/* Category filter */}
        {!query && (
          <div style={{ padding: '0 16px 10px', overflowX: 'auto' }}>
            <div style={{ display: 'flex', gap: 6, minWidth: 'max-content', paddingBottom: 4 }}>
              {(['All', 'India', ...CATEGORIES] as const).map(cat => {
                const isActive = activeCat === cat
                const color = cat === 'All' ? ACCENT : cat === 'India' ? '#ff8c00' : CAT_COLORS[cat] || ACCENT
                return (
                  <button key={cat} onClick={() => setActiveCat(cat as any)}
                    style={{
                      padding: '6px 12px', borderRadius: 8, border: `1px solid ${isActive ? color + '60' : BORDER}`,
                      background: isActive ? `${color}18` : CARD,
                      color: isActive ? color : DIM,
                      fontSize: 11, cursor: 'pointer', whiteSpace: 'nowrap',
                      fontWeight: isActive ? 700 : 400,
                    }}>
                    {cat === 'All' ? '✨ All' : cat === 'India' ? '🇮🇳 India' : `${CATEGORY_ICONS[cat as Category] || ''} ${cat}`}
                  </button>
                )
              })}
            </div>
          </div>
        )}

        {/* Search results header */}
        {query && (
          <div style={{ padding: '10px 16px 6px', fontSize: 11, color: DIM }}>
            "{query}" — {displayApps.length} results
          </div>
        )}

        {/* Apps list/grid */}
        <div style={{ padding: '0 16px' }}>
          {view === 'grid' ? (
            <div style={{ display: 'grid', gridTemplateColumns: 'repeat(4,1fr)', gap: 8 }}>
              {displayApps.map(app => <AppCard key={app.id} app={app} compact />)}
            </div>
          ) : (
            <div style={{ display: 'flex', flexDirection: 'column', gap: 8 }}>
              {/* Group by category when showing All */}
              {!query && activeCat === 'All'
                ? CATEGORIES.map(cat => {
                    const catApps = APPS.filter(a => a.category === cat)
                    if (!catApps.length) return null
                    const color = CAT_COLORS[cat] || ACCENT
                    return (
                      <div key={cat} style={{ marginBottom: 8 }}>
                        <div style={{ display: 'flex', alignItems: 'center', gap: 6, marginBottom: 8, padding: '6px 0' }}>
                          <span style={{ fontSize: 14 }}>{CATEGORY_ICONS[cat]}</span>
                          <span style={{ fontSize: 11, fontWeight: 700, color }}>{cat}</span>
                          <div style={{ flex: 1, height: 1, background: `${color}20` }} />
                          <span style={{ fontSize: 9, color: DIM }}>{catApps.length} apps</span>
                        </div>
                        {catApps.map(app => <AppCard key={app.id} app={app} />)}
                      </div>
                    )
                  })
                : displayApps.map(app => <AppCard key={app.id} app={app} />)
              }
            </div>
          )}

          {displayApps.length === 0 && query && (
            <div style={{ textAlign: 'center', padding: '40px 0', color: DIM }}>
              <div style={{ fontSize: 32 }}>🔍</div>
              <div style={{ marginTop: 8, fontSize: 13 }}>"{query}" — koi app nahi mila</div>
              <div style={{ fontSize: 11, marginTop: 4 }}>Try: design, code, pdf, neet, translate...</div>
            </div>
          )}
        </div>
      </main>

      <BottomNav />
    </div>
  )
}
